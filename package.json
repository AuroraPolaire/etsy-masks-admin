{
  "name": "etsy-masks-admin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run worker:typecheck && npm run pages:typecheck && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc -b && npm run worker:typecheck && npm run pages:typecheck",
    "worker:typecheck": "tsc -p worker/tsconfig.json --noEmit",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "worker:migrate:local": "wrangler d1 migrations apply etsy_masks_admin --local --config worker/wrangler.toml",
    "worker:migrate:remote": "wrangler d1 migrations apply etsy_masks_admin --remote --config worker/wrangler.toml",
    "pages:typecheck": "tsc -p tsconfig.pages.json --noEmit",
    "pages:functions:build": "wrangler pages functions build functions --outdir .wrangler/pages-functions --compatibility-date=2026-05-26",
    "pages:project:create": "wrangler pages project create etsy-masks-admin --production-branch main --compatibility-date=2026-05-26",
    "pages:secret:openai": "wrangler pages secret put OPENAI_API_KEY --project-name etsy-masks-admin",
    "pages:migrate:local": "wrangler d1 migrations apply etsy_masks_admin --local",
    "pages:migrate:remote": "wrangler d1 migrations apply etsy_masks_admin --remote",
    "pages:dev": "npm run build && wrangler pages dev dist --port 8788 --binding AUTH_MODE=none --binding APP_VERSION=dev --binding MAX_FILE_BYTES=52428800 --binding ALLOWED_ORIGINS=http://127.0.0.1:8788",
    "pages:deploy": "wrangler pages deploy dist --project-name etsy-masks-admin --branch main",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{css,html,json,md,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-photo-view": "^1.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cloudflare/workers-types": "^4.20260525.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.94.0"
  }
}
